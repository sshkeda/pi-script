{
  "name": "pi-script",
  "version": "0.2.0",
  "description": "Pi Script: a TypeScript-native single-tool mode for Pi.",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "pi": {
    "extensions": ["./index.ts"],
    "skills": ["./skills"]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 test/*.test.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "pi-context": "github:sshkeda/pi-context#v0.1.6",
    "pi-pending": "github:sshkeda/pi-pending#v0.1.5",
    "typebox": "latest",
    "typescript": "latest"
  },
  "devDependencies": {
    "pi-mock": "github:sshkeda/pi-mock"
  },
  "keywords": [
    "pi",
    "extension",
    "typescript",
    "script"
  ],
  "license": "MIT"
}
